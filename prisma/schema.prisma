// Win-Win API — PostgreSQL schema
// Локализация данных в РФ

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Пользователи ---
model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  passwordHash String?
  role      UserRole @default(USER)
  isActive  Boolean  @default(true)
  /// Согласие на обработку ПДн (отметка времени при регистрации).
  consentPersonalDataAcceptedAt DateTime?
  /// Согласие на SMS-уведомления/рассылку (не транзакционный OTP).
  consentSmsMarketingAcceptedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile        UserProfile?
  orders         Order[]
  collections    Collection[]
  referralsMade Referral[] @relation("referrer") // приглашения от этого пользователя
  referredAs    Referral?  @relation("referred") // не более одной записи: кто привёл текущего user
  referralRewards ReferralReward[]
  blogPosts       BlogPost[]
  favorites     Favorite[]
  cart          Cart?
  designer      Designer?         // публичная страница дизайнера (опционально)
  accountContactChallenges AccountContactChallenge[]
  designerInvitesSent      DesignerInvite[]     @relation("DesignerInviteInviter")

  cases Case[]
}

/// Приглашение дизайнера по email: ссылка с подписанным токеном, ref-код на момент отправки.
model DesignerInvite {
  id         String   @id @default(cuid())
  inviterId  String
  inviter    User     @relation("DesignerInviteInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  emailNorm  String
  refCode    String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([inviterId, createdAt])
  @@index([emailNorm])
}

enum UserRole {
  USER      // дизайнер / клиент
  MODERATOR // модератор каталога
  ADMIN     // суперадмин
}

enum RegistrationOtpChannel {
  PHONE
  EMAIL
}

/// OTP при регистрации: либо SMS на телефон, либо письмо на email.
model RegistrationChallenge {
  id                  String                  @id @default(cuid())
  channel             RegistrationOtpChannel
  /// Цифры без «+», например 79001234567; для регистрации по email — null
  phone               String?
  email               String?
  codeHash            String
  expiresAt           DateTime
  attempts            Int                     @default(0)
  consentPersonalData Boolean
  consentSms          Boolean
  createdAt           DateTime                @default(now())

  @@index([phone])
  @@index([email])
}

/// OTP для привязки/смены email или телефона у существующего пользователя (ЛК).
model AccountContactChallenge {
  id       String                 @id @default(cuid())
  userId   String
  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel  RegistrationOtpChannel
  newPhone String?
  newEmail String?
  codeHash String
  expiresAt DateTime
  attempts Int                    @default(0)
  createdAt DateTime               @default(now())

  @@index([userId])
  @@index([newPhone])
  @@index([newEmail])
}

model UserProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName    String?
  lastName     String?
  avatarUrl    String?
  /// Город для публичного превью профиля дизайнера
  city         String?
  /// Коды/метки услуг (мультивыбор в ЛК)
  services     Json?
  /// HTML «Подробнее о вас»
  aboutHtml    String?   @db.Text
  /// Сетка обложки: "4:3" | "16:9"
  coverLayout  String?
  /// URL обложек (1–2 для 4:3, 1 для 16:9) — те же S3-ключи, что и медиатека `objects/…`
  coverImageUrls Json?
  /// После первого захода в ЛК после регистрации показываем `/account/profile` (таб «Инфо») один раз
  profileOnboardingPending Boolean @default(true)
  /// Партнёр Win-Win: одобрено админом (реферальная программа, разделы Кейсы/Команда/Проекты и т.д.)
  winWinPartnerApproved Boolean @default(false)
  /// Заявка на партнёра: сопроводительный текст
  partnerApplicationCoverLetter  String?   @db.Text
  /// Заявка: URL CV в хранилище
  partnerApplicationCvUrl         String?
  /// Заявка: время подачи (пока null — заявка не подана)
  partnerApplicationSubmittedAt   DateTime?
  /// Админ отклонил заявку (в очереди снова не показываем; повторная подача снимает)
  partnerApplicationRejectedAt     DateTime?
  /// Реферальный номер приглашающего (если требуется; для «первых» / exempt — null)
  partnerApplicationReferralCode  String?
  /// Публичный реф. код партнёра (только у одобренных; для приглашения других)
  winWinReferralCode              String?  @unique
  legalType    LegalType? @default(INDIVIDUAL)
  companyName  String?
  inn          String?
  kpp          String?
  legalAddress String?
  bankName     String?
  bankAccount  String?
  // KYC (Этап 7)
  kycStatus    KycStatus? @default(NOT_STARTED)
  kycData      Json?     // документы, верификация
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

/// Кейсы дизайнера (создаются в ЛК; доступны только одобренным партнёрам Win-Win).
model Case {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title            String
  shortDescription String? @db.VarChar(400)
  location         String?
  year             Int?
  budget           String?

  /// HTML из RichBlock
  descriptionHtml String? @db.Text

  /// Сетка обложки: "4:3" | "16:9"
  coverLayout String?
  /// URL обложек (1–2 для 4:3, 1 для 16:9)
  coverImageUrls Json?

  /// Типы помещений (массив строк, значения из SiteSettings.caseRoomTypeOptions)
  roomTypes Json?

  /// ID товаров каталога, использованных в проекте (JSON-массив строк)
  productIds Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt(sort: Desc)])
}

enum KycStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum LegalType {
  INDIVIDUAL  // физлицо
  IE          // ИП
  LLC         // ООО
}

// --- Бренды (Этап 2: страницы всех брендов, страница бренда) ---
model Brand {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  /// Короткое описание для витрины (до 400 символов)
  shortDescription String? @db.VarChar(400)
  description String?   @db.Text // HTML из RichBlock (админка)
  logoUrl     String?
  siteUrl     String?
  coverImageUrl       String?
  backgroundImageUrl  String?
  galleryImageUrls    Json? // до 3 URL доп. изображений (массив строк)
  seoTitle            String?
  seoDescription      String?   @db.Text
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]
  curatedCollectionBrandItems CuratedCollectionBrandItem[]
  curatedProductSets       CuratedProductSet[]
  /// Библиотека материалов бренда (используется в модификациях товаров этого бренда).
  materials BrandMaterial[]
}

/// Материал бренда (группа в библиотеке «Материалы → Цвета»).
model BrandMaterial {
  id        String   @id @default(cuid())
  brandId   String
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  colors BrandMaterialColor[]

  @@index([brandId])
}

/// Конкретный цвет материала бренда (ключевая сущность выбора в варианте).
model BrandMaterialColor {
  id              String        @id @default(cuid())
  brandMaterialId String
  brandMaterial   BrandMaterial @relation(fields: [brandMaterialId], references: [id], onDelete: Cascade)
  name            String
  imageUrl        String?
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  elementAvailabilities ProductElementMaterialColor[]
  variantSelections     ProductVariantElementSelection[]

  @@index([brandMaterialId])
}

// --- Каталог (категории/подкатегории по parentId) ---
model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  seoTitle       String?  // meta title для витрины
  seoDescription String?  @db.Text // meta description для витрины
  backgroundImageUrl String? // URL фона категории (S3/CDN)
  backgroundMediaObjectId String?
  backgroundMediaObject   MediaObject? @relation(fields: [backgroundMediaObjectId], references: [id], onDelete: SetNull)
  parentId    String?
  parent      Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryToCategory")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Товары, у которых эта категория основная (Product.categoryId)
  primaryProducts Product[] @relation("ProductPrimaryCategory")
  /// Дополнительные привязки товаров к этой категории
  productCategories ProductCategory[]
  pricingProfileCategories PricingProfileCategory[]
}

/// Профиль ценообразования (импорт Китай → склад МСК), привязка к категориям.
model PricingProfile {
  id     String @id @default(cuid())
  name   String @default("")
  /// Порядок в списке админки
  sortOrder Int @default(0)
  /// "40" | "20" — тип контейнера для расчёта доли
  containerType String
  /// Если заданы оба — W90/V90 = 0,9 × эти лимиты; иначе константы по containerType
  containerMaxWeightKg  Decimal? @db.Decimal(14, 4)
  containerMaxVolumeM3  Decimal? @db.Decimal(14, 6)

  cnyRate Decimal @db.Decimal(14, 6)
  usdRate Decimal @db.Decimal(14, 6)
  eurRate Decimal @db.Decimal(14, 6)

  transferCommissionPct Decimal @db.Decimal(10, 4)
  customsAdValoremPct   Decimal @db.Decimal(10, 4)
  customsWeightPct      Decimal @db.Decimal(10, 4)
  vatPct                Decimal @db.Decimal(10, 4)
  markupPct             Decimal @db.Decimal(10, 4)
  agentRub              Decimal @db.Decimal(14, 2)

  warehousePortUsd  Decimal @db.Decimal(14, 2)
  fobUsd            Decimal @db.Decimal(14, 2)
  portMskRub        Decimal @db.Decimal(14, 2)
  extraLogisticsRub Decimal @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories PricingProfileCategory[]
}

model PricingProfileCategory {
  profileId  String
  categoryId String
  profile    PricingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  category   Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([profileId, categoryId])
  @@index([categoryId])
}

enum ProductPriceMode {
  MANUAL
  FORMULA
}

/// Дополнительные категории товара (основная — всегда Product.categoryId).
model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  categoryId  String
  category    Category @relation("ProductPrimaryCategory", fields: [categoryId], references: [id])
  brandId     String?
  brand       Brand?   @relation(fields: [brandId], references: [id])
  name        String
  description String?  @db.Text
  /// Карточка / списки (plain)
  shortDescription String? @db.Text
  /// HTML из RichBlock (доп. информация на витрине)
  additionalInfoHtml String? @db.Text
  /// @deprecated Не используется в новых сценариях; опции SKU — в `ProductVariant` / материалах.
  attributes  Json?
  deliveryText    String? @db.Text
  technicalSpecs  String? @db.Text
  seoTitle       String?
  seoDescription String? @db.Text
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images           ProductImage[]
  videos           ProductVideo[]
  variants         ProductVariant[]
  orderItems       OrderItem[]
  collectionItems  CollectionItem[]
  cartItems        CartItem[]
  publicCollectionItems PublicCollectionItem[]
  productCategories ProductCategory[]
  curatedCollectionProductItems CuratedCollectionProductItem[]
  curatedProductSetItems      CuratedProductSetItem[]
  modifications    ProductModification[]
  elements         ProductElement[]
}

/// Модификация товара (размер/конфигурация). Простой товар может иметь одну модификацию без элементов.
model ProductModification {
  id               String  @id @default(cuid())
  productId        String
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  /// Подпись (пример: «2000x800 — большой угловой диван»).
  name             String
  /// Сегмент URL: /product/{slug}?m={modificationSlug}
  modificationSlug String?
  sortOrder        Int     @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  variants ProductVariant[]

  @@index([productId])
}

/// Настраиваемый элемент товара (обивка, ножки, корпус, фасад …). Общий пул на товар — используется всеми модификациями.
model ProductElement {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  availabilities    ProductElementMaterialColor[]
  variantSelections ProductVariantElementSelection[]

  @@index([productId])
}

/// Пул доступных «материал-цветов» (из библиотеки бренда) для конкретного элемента.
model ProductElementMaterialColor {
  productElementId     String
  brandMaterialColorId String
  sortOrder            Int @default(0)
  productElement       ProductElement     @relation(fields: [productElementId], references: [id], onDelete: Cascade)
  brandMaterialColor   BrandMaterialColor @relation(fields: [brandMaterialColorId], references: [id], onDelete: Cascade)

  @@id([productElementId, brandMaterialColorId])
  @@index([brandMaterialColorId])
}

/// Кадры варианта — подмножество ProductImage (порядок в sortOrder).
model ProductVariantProductImage {
  variantId      String
  productImageId String
  sortOrder      Int @default(0)
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  productImage   ProductImage @relation(fields: [productImageId], references: [id], onDelete: Cascade)

  @@id([variantId, productImageId])
  @@index([variantId])
}

/// Вариант товара (SKU): цена, габариты, артикул; ровно одна модификация + по одной «материал-цвет» на элемент.
model ProductVariant {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  modificationId String
  modification   ProductModification @relation(fields: [modificationId], references: [id], onDelete: Restrict)
  sortOrder      Int      @default(0)
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  /// Подпись варианта в админке и на PDP. Авто-генерация на сервере, если не задано (размер + selections).
  variantLabel   String?
  /// Сегмент URL: /product/{productSlug}?vs={variantSlug}
  variantSlug    String?
  sku            String?  @unique
  lengthMm       Int?
  widthMm        Int?
  heightMm       Int?
  volumeLiters   Decimal? @db.Decimal(12, 4)
  weightKg       Decimal? @db.Decimal(12, 4)
  netLengthMm    Int?
  netWidthMm     Int?
  netHeightMm    Int?
  netVolumeLiters Decimal? @db.Decimal(12, 4)
  netWeightKg     Decimal? @db.Decimal(12, 4)
  priceMode      ProductPriceMode @default(MANUAL)
  costPriceCny   Decimal? @db.Decimal(14, 4)
  price          Decimal  @db.Decimal(12, 2)
  currency       String   @default("RUB")
  /// 3D-модель (GLB и т.п.)
  model3dUrl     String?
  /// Чертёж (PDF и т.п.)
  drawingUrl     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  variantProductImages ProductVariantProductImage[]
  elementSelections    ProductVariantElementSelection[]
  favorites  Favorite[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@index([modificationId])
  @@unique([productId, variantSlug])
}

/// Выбор «материал-цвет» для элемента внутри варианта.
model ProductVariantElementSelection {
  variantId            String
  productElementId     String
  brandMaterialColorId String
  variant              ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  productElement       ProductElement @relation(fields: [productElementId], references: [id], onDelete: Cascade)
  brandMaterialColor   BrandMaterialColor @relation(fields: [brandMaterialColorId], references: [id], onDelete: Restrict)

  @@id([variantId, productElementId])
  @@index([productElementId])
  @@index([brandMaterialColorId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String  // URL в объектном хранилище (S3-совместимое в РФ) или CDN
  alt       String?
  sortOrder Int     @default(0)
  variantLinks ProductVariantProductImage[]
}

model ProductVideo {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String  // URL видео в объектном хранилище (S3-совместимое в РФ) или CDN
  title    String?
  sortOrder Int     @default(0)
}

// --- Заказы (статусы вручную, оплаты оффлайн) ---
model Order {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  status      OrderStatus @default(ORDERED)
  totalAmount Decimal   @db.Decimal(12, 2)
  currency    String    @default("RUB")
  comment     String?   @db.Text
  // Документы загружаются вручную — ссылки на файлы
  documentUrls Json?    // { "invoice": "...", "act": "...", "waybill": "..." }
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items OrderItem[]
}

enum OrderStatus {
  ORDERED   // Заказано
  PAID      // Оплачено
  RECEIVED  // Получено
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(12, 2)
}

// --- Коллекции (личные, шаринг по ссылке) ---
model Collection {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  shareToken  String?  @unique // для доступа по ссылке
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items CollectionItem[]
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder    Int        @default(0)
  addedAt      DateTime   @default(now())
}

enum CuratedCollectionKind {
  PRODUCT
  BRAND
}

/// Редакторские коллекции для витрины (админка). Отдельно от личных Collection.
model CuratedCollection {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  coverImageUrl          String?
  coverMediaObjectId     String?
  coverMediaObject       MediaObject? @relation(fields: [coverMediaObjectId], references: [id], onDelete: SetNull)
  seoTitle       String?
  seoDescription String?  @db.Text
  kind        CuratedCollectionKind
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productItems CuratedCollectionProductItem[]
  brandItems   CuratedCollectionBrandItem[]
}

model CuratedCollectionProductItem {
  id             String            @id @default(cuid())
  collectionId   String
  collection     CuratedCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId      String
  product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder      Int               @default(0)

  @@unique([collectionId, productId])
  @@index([collectionId])
}

model CuratedCollectionBrandItem {
  id             String            @id @default(cuid())
  collectionId   String
  collection     CuratedCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  brandId        String
  brand          Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  sortOrder      Int               @default(0)

  @@unique([collectionId, brandId])
  @@index([collectionId])
}

/// Редакторские наборы (только товары), аналог коллекций без типа «бренды».
model CuratedProductSet {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  brandId     String?
  brand       Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  coverImageUrl          String?
  coverMediaObjectId     String?
  coverMediaObject       MediaObject? @relation(fields: [coverMediaObjectId], references: [id], onDelete: SetNull)
  seoTitle       String?
  seoDescription String?  @db.Text
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items CuratedProductSetItem[]

  @@index([brandId])
}

model CuratedProductSetItem {
  id        String            @id @default(cuid())
  setId     String
  set       CuratedProductSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  productId String
  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder Int               @default(0)

  @@unique([setId, productId])
  @@index([setId])
}

// --- Дизайнеры (Этап 2: страница всех дизайнеров, страница дизайнера) ---
model Designer {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug        String   @unique
  displayName String
  bio         String?  @db.Text
  photoUrl    String?
  isPublic    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// --- Избранное: позиция = вариант SKU (одна звезда на вариант) ---
model Favorite {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@unique([userId, productVariantId])
}

// --- Корзина (Этап 4: страница корзины/заказа) ---
model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  items CartItem[]
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)
  addedAt   DateTime @default(now())

  @@unique([cartId, productVariantId])
}

// --- Публичные коллекции платформы (Этап 11: страница коллекций, страница коллекции) ---
model PublicCollection {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items PublicCollectionItem[]
}

model PublicCollectionItem {
  id                   String           @id @default(cuid())
  publicCollectionId   String
  publicCollection     PublicCollection @relation(fields: [publicCollectionId], references: [id], onDelete: Cascade)
  productId            String
  product              Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder            Int              @default(0)
  addedAt              DateTime         @default(now())
}

// --- Информационные страницы + О нас (Этап 11–12) ---
model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  body        String   @db.Text
  type        PageType @default(CUSTOM) // about, services, delivery, payment, contacts, custom
  sortOrder   Int      @default(0)
  isPublished Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PageType {
  ABOUT     // О нас
  SERVICES  // Услуги
  DELIVERY  // Доставка
  PAYMENT   // Оплата
  CONTACTS  // Контакты
  CUSTOM    // Произвольная информационная
}

// --- Реферальная программа (2 уровня) ---
model Referral {
  id           String   @id @default(cuid())
  referrerId   String   // кто привёл
  referrer     User     @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId   String   @unique // кого привели
  referred     User     @relation("referred", fields: [referredId], references: [id], onDelete: Cascade)
  level        Int      // 1 или 2
  createdAt    DateTime @default(now())
}

model ReferralConfig {
  id          String   @id @default(cuid())
  key         String   @unique // level1_percent, level2_percent, level1_fixed, ...
  value       String   // число или JSON
  description String?
  updatedAt   DateTime @updatedAt
}

model ReferralReward {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId      String   // заказ реферала
  level        Int      // 1 или 2
  amount       Decimal  @db.Decimal(12, 2)
  status       RewardStatus @default(PENDING)
  paidAt       DateTime?
  createdAt    DateTime @default(now())
}

enum RewardStatus {
  PENDING
  INVOICED  // выставлен инвойс платформе
  PAID
}

enum MediaLibraryCategory {
  IMAGE
  DOCUMENT
  MODEL
  VIDEO
  OTHER
}

// --- Медиатека S3 (админка: обложки, RichBlock, документы) ---
model MediaFolder {
  id          String   @id @default(cuid())
  name        String
  slugSegment String
  parentId    String?
  parent      MediaFolder?  @relation("MediaFolderTree", fields: [parentId], references: [id], onDelete: Restrict)
  children    MediaFolder[] @relation("MediaFolderTree")
  pathKey     String   @unique // напр. "marketing/banners" для префикса objects/… в S3
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  objects     MediaObject[]

  @@unique([parentId, slugSegment])
}

model MediaObject {
  id           String               @id @default(cuid())
  storageKey   String               @unique
  originalName String
  mimeType     String
  category     MediaLibraryCategory @default(OTHER)
  byteSize     Int
  width        Int?
  height       Int?
  altText      String?
  folderId     String?
  folder       MediaFolder?         @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  categoryBackgrounds Category[]
  curatedCollectionCovers CuratedCollection[]
  curatedProductSetCovers CuratedProductSet[]
}

// --- Блог ---
model BlogCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  sortOrder Int      @default(0)
  posts     BlogPost[]
}

model BlogPost {
  id         String   @id @default(cuid())
  slug       String   @unique
  categoryId String?
  category   BlogCategory? @relation(fields: [categoryId], references: [id])
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id])
  title      String
  excerpt    String?  @db.Text
  body       String   @db.Text
  coverUrl   String?
  isPublished Boolean @default(false)
  publishedAt DateTime?
  /// Порядок в админке и на витрине (меньше — выше).
  sortOrder   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// --- Аудит (админка и критичные действия) ---
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  UPLOAD
  LOGIN
  LOGIN_FAILED
}

model AuditLog {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  actorUserId  String?
  actorEmail   String?
  actorRole    String?
  action       AuditAction
  entityType   String?
  entityId     String?
  httpMethod   String?
  path         String
  metadata     Json?
  ip           String?
  userAgent    String?

  @@index([createdAt(sort: Desc)])
  @@index([actorUserId])
  @@index([action])
}

/// Настройки витрины (singleton: 1 строка).
model SiteSettings {
  id String @id @default("site")

  /// Изображения hero на главной (до 8 URL), порядок важен.
  heroImageUrls Json?

  /// Список услуг для мультиселекта в профиле дизайнера (массив строк).
  designerServiceOptions Json?

  /// Типы помещений для кейсов дизайнера (массив строк).
  caseRoomTypeOptions Json?

  updatedAt DateTime @updatedAt
}
