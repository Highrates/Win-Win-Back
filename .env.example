# Server
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database — локальная разработка: отдельная БД winwin_dev (docs/DEPLOY.md §1.3).
# На VPS в .env бэка обычно: postgresql://winwin:ПАРОЛЬ@localhost:5432/winwin
DATABASE_URL="postgresql://winwin:admin-winwin@localhost:5432/winwin_dev"

# Redis (self-hosted в РФ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Meilisearch (self-hosted в РФ)
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Первичный администратор — после миграций: npx prisma db seed
# Email нормализуется в нижний регистр; у пароля обрезаются пробелы по краям.
ADMIN_SEED_EMAIL=admin@winwin.local
ADMIN_SEED_PASSWORD=winwin@2026

# Сессии / cookie (опционально)
SESSION_SECRET=session-secret-change-in-production

# S3-совместимое хранилище (РФ) — загрузка фона категорий в админке.
S3_REGION=ru-central1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Публичный базовый URL объектов (CDN или endpoint bucket), без завершающего /
S3_PUBLIC_BASE_URL=
# Для MinIO и части провайдеров: https://minio.example.com и S3_FORCE_PATH_STYLE=1
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=0
# Рег.облако S3 (пример): endpoint https://s3.regru.cloud , публичные URL — virtual-hosted
#   https://ИМЯ_БАКЕТА.website.regru.cloud (без / в конце). Часто S3_FORCE_PATH_STYLE=1 .
# Регион подписи — из панели «Параметры набора ключей»; иначе оставьте ru-central1 или попробуйте us-east-1.

# Локальные загрузки без S3 (папка на диске + раздача /uploads с этого API).
# В NODE_ENV=development, если S3 не задан, локальный режим включается сам; файл → .data/local-uploads, URL → http://127.0.0.1:PORT/uploads/...
# Явно отключить в dev: LOCAL_UPLOADS_ENABLED=0
# На production без S3: LOCAL_UPLOADS_ENABLED=1 и выставьте публичный URL API.
LOCAL_UPLOADS_ENABLED=
LOCAL_UPLOADS_DIR=
# Как браузер открывает файлы (тот же хост, что и Nest, с портом при прямом доступе)
LOCAL_UPLOADS_PUBLIC_URL=
