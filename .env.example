# Server
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database — локальная разработка: отдельная БД winwin_dev (docs/DEPLOY.md §1.3).
# На VPS в .env бэка обычно: postgresql://winwin:ПАРОЛЬ@localhost:5432/winwin
DATABASE_URL="postgresql://winwin:admin-winwin@localhost:5432/winwin_dev"

# Redis (self-hosted в РФ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Поиск каталога (Meilisearch, self-hosted в РФ) ---
# MEILISEARCH_ENABLED=false — GET /api/v1/catalog/products/search ходит в PostgreSQL.
# true — нужен запущенный Meilisearch (MEILISEARCH_HOST, при защите — MEILISEARCH_API_KEY).
# После первого включения на проде: из каталога backend выполнить один раз:
#   npm run meili:reindex
# (скрипт scripts/reindex-products-meilisearch.ts — полная переиндексация товаров).
# Дальше индекс подстраивается при create/update/delete товара в админке.
MEILISEARCH_ENABLED=false
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# --- Приглашение дизайнера (партнёр шлёт ссылку по email; ссылка в письме, JWT typ=dinv, срок 14 д) ---
# Публичный URL фронта для ссылки в письме, без завершающего /. Иначе подставляется NEXT_PUBLIC_SITE_URL (если задана в окружении процесса API), затем заглушка.
FRONTEND_PUBLIC_URL=http://127.0.0.1:3000
# Отдельный секрет для JWT приглашений. Пусто — используется JWT_SECRET.
# DESIGNER_INVITE_JWT_SECRET=

# Заявка «Стать партнёром»: email (через запятую), для которых не требуется реферальный номер приглашающего.
# Пример: WINWIN_REFERRAL_EXEMPT_EMAILS=founder@example.com
WINWIN_REFERRAL_EXEMPT_EMAILS=

# Первичный администратор — после миграций: npx prisma db seed
# Email нормализуется в нижний регистр; у пароля обрезаются пробелы по краям.
ADMIN_SEED_EMAIL=admin@winwin.local
ADMIN_SEED_PASSWORD=winwin@2026

# Сессии / cookie (опционально)
SESSION_SECRET=session-secret-change-in-production

# S3-совместимое хранилище (РФ) — загрузка фона категорий в админке.
S3_REGION=ru-central1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Публичный базовый URL объектов (CDN или endpoint bucket), без завершающего /
S3_PUBLIC_BASE_URL=

# --- Каталог: строгие URL медиа и удаление из бакета (важно для прода) ---
# Галерея товара, цвета, 3D/чертеж и т.п.: API принимает URL только своего хранилища
# (S3_PUBLIC_BASE_URL / локальные /uploads) или хосты из списка ниже. Иначе — 400.
# Прод без whitelist и без своего домена в URL часто «ломается» на первой загрузке с CDN.
# PRODUCT_IMAGE_URL_HOST_WHITELIST=cdn.example.com,img.other.ru
PRODUCT_IMAGE_URL_HOST_WHITELIST=
# При удалении товара или строки галереи по умолчанию НЕ удаляются ключи objects/…
# (медиатека; один файл могут использовать несколько сущностей).
# true — удалять и objects/ (риск: снять файл, который ещё где-то используется).
PRODUCT_DELETE_MEDIATHEK_STORAGE_KEYS=false
# Для MinIO и части провайдеров: https://minio.example.com и S3_FORCE_PATH_STYLE=1
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=0
# Рег.облако S3: S3_ENDPOINT=https://s3.regru.cloud , S3_FORCE_PATH_STYLE=1 .
# Публичный URL для браузера — path-style (см. вкладка бакета «Подключение»):
#   S3_PUBLIC_BASE_URL=https://s3.regru.cloud/ИМЯ_БАКЕТА  (не *.website.regru.cloud — часто 404 для API-загрузок).
# Регион подписи — из панели «Параметры набора ключей».

# Периодическая уборка ключей в бакете под objects/, отсутствующих в MediaObject (мс). 0 = выключено.
# Ручной запуск: POST /api/v1/catalog/admin/media/maintenance/sweep-orphan-objects (JWT админа).
# MEDIA_LIBRARY_SWEEP_INTERVAL_MS=86400000

# Локальные загрузки без S3 (папка на диске + раздача /uploads с этого API).
# В NODE_ENV=development, если S3 не задан, локальный режим включается сам; файл → .data/local-uploads, URL → http://127.0.0.1:PORT/uploads/...
# Явно отключить в dev: LOCAL_UPLOADS_ENABLED=0
# На production без S3: LOCAL_UPLOADS_ENABLED=1 и выставьте публичный URL API.
# Админка «Объекты» (/admin/objects) и любые загрузки в медиатеку требуют либо полного S3 (bucket + ключи + S3_PUBLIC_BASE_URL), либо LOCAL_UPLOADS_ENABLED=1.
LOCAL_UPLOADS_ENABLED=
LOCAL_UPLOADS_DIR=
# Как браузер открывает файлы (тот же хост, что и Nest, с портом при прямом доступе)
LOCAL_UPLOADS_PUBLIC_URL=

# Аудит (журнал админки): экономия места и ротация.
# Не писать User-Agent в каждую строку (экономия текста в БД).
# AUDIT_STORE_USER_AGENT=0
# Удалять записи старше N дней (раз в сутки + при старте API). Пусто = 90 дней. 0 = отключить авто-удаление.
AUDIT_RETENTION_DAYS=90
# Отдельный пароль для полной очистки журнала (POST …/audit/admin/purge, только роль ADMIN). Сильная случайная строка.
AUDIT_JOURNAL_PURGE_PASSWORD=change-me-to-long-random-secret

# --- Регистрация: OTP по SMS (Unimatrix) при регистрации по телефону; OTP по SMTP при регистрации по email ---
# Документация: https://www.unimtx.com/docs/api/general — query: action, accessKeyId (Simple mode).
# SMS отправка: https://www.unimtx.com/docs/api/send (action=sms.message.send, signature + content).
UNIMTX_ACCESS_KEY_ID=
# Approved sender из Unimtx Console → Messaging → Senders (например, Win-win).
# Строка должна совпадать с консолью посимвольно (иначе SmsSignatureNotExists).
UNIMTX_SMS_SIGNATURE=
# По умолчанию при отправке по UNIMTX_SMS_TEMPLATE_ID поле signature в API не шлём (отправитель уже у шаблона).
# Если поддержка Unimtx попросила явно передавать имя — UNIMTX_SMS_SIGNATURE_WITH_TEMPLATE=1
# UNIMTX_SMS_SIGNATURE_WITH_TEMPLATE=0
# Если API возвращает SmsTemplateNotExists (107141) — заведите шаблон в Unimtx Console → Messaging → Templates
# и укажите его id/код здесь. В send используем templateData: { code, ttl }.
# Пример: UNIMTX_SMS_TEMPLATE_ID=5fce799c (winwin_otp_ru)
# UNIMTX_SMS_TEMPLATE_ID=
# Базовый URL API (см. https://www.unimtx.com/docs/regions — Global / Europe / Singapore).
# При «fetch failed» / таймауте SSL к api.unimtx.com попробуйте, например:
# UNIMTX_API_BASE_URL=https://api-eu.unimtx.com
# UNIMTX_API_BASE_URL=https://api-sg.unimtx.com
# UNIMTX_API_BASE_URL=https://api.unimtx.com
# Таймаут HTTP к Unimtx (мс), по умолчанию 25000.
# UNIMTX_REQUEST_TIMEOUT_MS=25000

# На проде обязательно задать; иначе регистрация по email упадёт. Исходящие 587 (STARTTLS) или 465 часто режут файрволом VPS.
SMTP_HOST=
# По умолчанию подключение только по IPv4 (A-запись), чтобы на VPS без маршрута IPv6 не ловить ENETUNREACH к AAAA (напр. Gmail 2a00:1450:…).
# Если SMTP доступен только по IPv6 — SMTP_FORCE_IPV4=0
SMTP_FORCE_IPV4=1
SMTP_PORT=587
SMTP_SECURE=false
# На порту 587 по умолчанию включается requireTLS. Если провайдер ругается на STARTTLS — попробуйте SMTP_REQUIRE_TLS=0
# SMTP_REQUIRE_TLS=0
SMTP_USER=
SMTP_PASSWORD=
# Пароль приложения Gmail без пробелов или с пробелами — при отправке пробелы убираются.
MAIL_FROM="Win-Win <noreply@example.com>"

# Отдельный секрет для JWT «завершить регистрацию» (после OTP). Пусто = используется JWT_SECRET.
REGISTRATION_TOKEN_SECRET=
